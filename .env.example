# Database — Supabase PostgreSQL connection string
DATABASE_URL=

# Auth.js v5
AUTH_URL=http://localhost:3000
AUTH_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Apple OAuth — https://developer.apple.com/account/resources/identifiers
# Set all three to enable Apple sign-in (provider + UI button)
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=
NEXT_PUBLIC_APPLE_ENABLED=

# Tesla OAuth (account linking) — https://developer.tesla.com
# Set both to enable Tesla account linking on the Settings page
AUTH_TESLA_ID=
AUTH_TESLA_SECRET=

# Real-time telemetry — WebSocket URL of the Go telemetry server
# The useVehicleStream hook appends /api/ws to this URL
# Local dev: ws://localhost:8080  |  Production: wss://telemetry.myrobotaxi.app
NEXT_PUBLIC_WS_URL=

# Telemetry server REST API — used server-side for fleet config push
# Local dev: http://localhost:8080  |  Production: https://telemetry.myrobotaxi.app
TELEMETRY_API_URL=

# Mapbox GL JS — https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=

# Beta access gate — set to require a password before sign-in (remove to disable)
BETA_ACCESS_PASSWORD=

# Sentry — https://sentry.io
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Column-level encryption (MYR-62) — AES-256-GCM key for OAuth token columns.
# Match the value used by the Go telemetry service so rows encrypted by either
# side are decryptable by the other. See lib/cryptox for the wire format.
#
# Single-key shorthand (v1 deployments before any rotation):
#   ENCRYPTION_KEY=<base64(32B)>
#
# Versioned shape (during/after a rotation):
#   ENCRYPTION_KEY_V1=<base64(32B)>
#   ENCRYPTION_KEY_V2=<base64(32B)>
#   ENCRYPTION_WRITE_VERSION=2
#
# Generate a new key with: openssl rand -base64 32
ENCRYPTION_KEY=
